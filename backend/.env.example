# Violet Backend Environment Template
PROJECT_NAME="Violet AI Personal Assistant"

# Production DB connection string (Neon PostgreSQL, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Token Cryptography Keys
JWT_SECRET_KEY="replace-with-a-secure-long-random-32-byte-hex-string"
JWT_REFRESH_SECRET_KEY="replace-with-a-secure-long-random-32-byte-hex-string"

# Token Lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
